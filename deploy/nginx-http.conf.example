server {
    listen 80;
    listen [::]:80;
    server_name jprq.example.com;

    root /var/www/jprq;
    location / { try_files $uri $uri/ =404; }
}

server {
    listen 80;
    listen [::]:80;
    server_name *.jprq.example.com;

    location / {
        proxy_pass http://127.0.0.1:18080;
        proxy_http_version 1.1;
        proxy_set_header Host $http_host;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_request_buffering off;
    }
}
