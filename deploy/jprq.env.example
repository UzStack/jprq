JPRQ_DOMAIN=jprq.example.com
# Choose either JPRQ_AUTH_TOKEN or the GitHub OAuth settings below.
# JPRQ_AUTH_TOKEN=replace-with-a-long-random-token
GITHUB_CLIENT_ID=replace-with-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-oauth-client-secret
GITHUB_REDIRECT_URI=https://jprq.example.com/oauth-callback
JPRQ_WEBSITE_ADDR=127.0.0.1:13300
JPRQ_EVENT_HOST=0.0.0.0
JPRQ_EVENT_PORT=4321
JPRQ_HTTP_HOST=127.0.0.1
JPRQ_HTTP_PORT=18080
JPRQ_TLS_DISABLED=1
